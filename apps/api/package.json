{
  "name": "@clr-vault/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "clean": "rm -rf dist",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "exif-reader": "^2.0.1",
    "fastify": "^4.28.0",
    "jose": "^5.0.0",
    "file-type": "^19.6.0",
    "lru-cache": "^11.0.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "sharp": "^0.33.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@clr-vault/shared": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.0",
    "prisma": "^5.22.0",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
