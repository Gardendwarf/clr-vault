generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum AssetStatus {
  PROCESSING
  ACTIVE
  ARCHIVED
  ERROR
}

enum AssetVisibility {
  PUBLIC
  PRIVATE
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         UserRole @default(USER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens RefreshToken[]
  apiKeys       ApiKey[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model ApiKey {
  id          String   @id @default(uuid())
  userId      String
  name        String
  appId       String   @unique
  keyHash     String
  keyPrefix   String
  permissions String[] @default(["read"])
  rateLimit   Int      @default(100)
  quotaBytes  BigInt   @default(5368709120)
  usedBytes   BigInt   @default(0)
  isActive    Boolean  @default(true)
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id])
  assets     Asset[]
  accessLogs AccessLog[]

  @@map("api_keys")
}

model Collection {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  parentId  String?
  path      String   @default("/")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent   Collection?       @relation("CollectionHierarchy", fields: [parentId], references: [id])
  children Collection[]      @relation("CollectionHierarchy")
  assets   AssetCollection[]

  @@map("collections")
}

model Asset {
  id           String          @id @default(uuid())
  apiKeyId     String?
  filename     String
  originalName String
  mimeType     String
  sizeBytes    BigInt
  storageKey   String          @unique
  contentHash  String
  status       AssetStatus     @default(PROCESSING)
  visibility   AssetVisibility @default(PRIVATE)
  width        Int?
  height       Int?
  duration     Float?
  thumbnailKey String?
  metadata     Json?
  alt          String?
  caption      String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  apiKey         ApiKey?           @relation(fields: [apiKeyId], references: [id])
  tags           AssetTag[]
  collections    AssetCollection[]
  transformCache TransformCache[]
  accessLogs     AccessLog[]

  @@index([contentHash])
  @@index([mimeType])
  @@index([status])
  @@map("assets")
}

model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())

  assets AssetTag[]

  @@map("tags")
}

model AssetTag {
  id      String @id @default(uuid())
  assetId String
  tagId   String

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([assetId, tagId])
  @@map("asset_tags")
}

model AssetCollection {
  id           String @id @default(uuid())
  assetId      String
  collectionId String

  asset      Asset      @relation(fields: [assetId], references: [id], onDelete: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([assetId, collectionId])
  @@map("asset_collections")
}

model TransformCache {
  id             String   @id @default(uuid())
  assetId        String
  params         String
  storageKey     String   @unique
  sizeBytes      BigInt
  lastAccessedAt DateTime @default(now())
  createdAt      DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, params])
  @@map("transform_cache")
}

model AccessLog {
  id           String   @id @default(uuid())
  assetId      String?
  apiKeyId     String?
  action       String
  ip           String?
  bytesServed  BigInt   @default(0)
  responseTime Int?
  createdAt    DateTime @default(now())

  asset  Asset?  @relation(fields: [assetId], references: [id])
  apiKey ApiKey? @relation(fields: [apiKeyId], references: [id])

  @@index([assetId, createdAt])
  @@index([apiKeyId, createdAt])
  @@map("access_logs")
}
