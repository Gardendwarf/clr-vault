{
  "name": "clr-vault",
  "version": "1.0.0",
  "private": true,
  "description": "Internal Digital Asset Management for the clrTech ecosystem",
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "dev:api": "pnpm --filter @clr-vault/api dev",
    "dev:web": "pnpm --filter @clr-vault/web dev",
    "build": "pnpm -r build",
    "build:api": "pnpm --filter @clr-vault/api build",
    "build:web": "pnpm --filter @clr-vault/web build",
    "lint": "pnpm -r lint",
    "db:generate": "pnpm --filter @clr-vault/api db:generate",
    "db:push": "pnpm --filter @clr-vault/api db:push",
    "db:migrate": "pnpm --filter @clr-vault/api db:migrate",
    "db:seed": "pnpm --filter @clr-vault/api db:seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build",
    "clean": "pnpm -r clean"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
