# ClrVault Environment Configuration

NODE_ENV=development
PORT=4030
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://clrvault:clrvault_dev@localhost:5442/clrvault?schema=public

# JWT
JWT_SECRET=change-this-to-a-secure-random-string-at-least-32-chars
JWT_REFRESH_SECRET=change-this-to-another-secure-random-string-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# R2/S3 Storage (MinIO for local dev)
R2_ENDPOINT=http://localhost:9000
R2_BUCKET=clrvault
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_PUBLIC_URL=http://localhost:9000/clrvault
R2_REGION=auto

# Workers
THUMBNAIL_WORKER_ENABLED=true
METADATA_WORKER_ENABLED=true
USAGE_AGGREGATION_ENABLED=true
WORKER_POLL_INTERVAL_MS=5000

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Upload Limits
MAX_FILE_SIZE_MB=500
MAX_MULTIPART_FILES=10

# Supabase JWT
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
CLRHUB_URL=https://hub.clrtech.xyz

# Frontend
VITE_API_URL=http://localhost:4030
